});

// ===== TRIP PLANNER FUNCTIONALITY =====
const plannerForm = document.querySelector('.planner-form');

if (plannerForm) {
    plannerForm.addEventListener('submit', async function(e) {
        e.preventDefault();

        const formData = {
            startLocation: document.getElementById('start-location').value.trim(),
            destination: document.getElementById('destination').value.trim(),
            travelDate: document.getElementById('travel-date').value,
            returnDate: document.getElementById('return-date').value,
            travelers: parseInt(document.getElementById('travelers').value) || 1,
            transport: document.getElementById('transport').value
        };

        // Validate form
        if (!validatePlannerForm(formData)) return;

        // Show loading state
        const submitBtn = plannerForm.querySelector('.planner-btn');
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner"></span> Generating Plan...';

        try {
            // Generate trip plan
            const tripPlan = await generateTripPlan(formData);

            // Display the plan
            displayTripPlan(tripPlan, formData);

            showToast('Trip plan generated successfully!', 'success');

        } catch (error) {
            console.error('Error generating trip plan:', error);
            showToast('Error generating trip plan. Please try again.', 'error');
        } finally {
            // Reset loading state
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Generate Plan';
        }
    });
}

async function generateTripPlan(formData) {
    // Calculate trip duration
    const startDate = new Date(formData.travelDate);
    const endDate = formData.returnDate ? new Date(formData.returnDate) : new Date(startDate.getTime() + 7 * 24 * 60 * 60 * 1000); // Default 7 days
    const duration = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24)) + 1;

    // Base costs (in INR)
    const transportCosts = {
        'Flight': 5000,
        'Train': 1200,
        'Bus': 800,
        'Cab': 3000
    };

    const accommodationCost = 2500; // per night per person
    const foodCost = 800; // per day per person
    const activitiesCost = 1500; // per day for group

    // Calculate costs
    const transportCost = transportCosts[formData.transport] * formData.travelers;
    const accommodationTotal = accommodationCost * (duration - 1) * formData.travelers; // Don't count departure day
    const foodTotal = foodCost * duration * formData.travelers;
    const activitiesTotal = activitiesCost * duration;
    const totalCost = transportCost + accommodationTotal + foodTotal + activitiesTotal;

    // Generate itinerary
    const itinerary = generateItinerary(formData, duration);

    return {
        duration,
        costs: {
            transport: transportCost,
            accommodation: accommodationTotal,
            food: foodTotal,
            activities: activitiesTotal,
            total: totalCost
        },
        itinerary,
        recommendations: generateRecommendations(formData.destination, formData.transport)
    };
}

function generateItinerary(formData, duration) {
    const itinerary = [];
    const startDate = new Date(formData.travelDate);

    // Day 1: Departure
    itinerary.push({
        day: 1,
        date: startDate.toLocaleDateString(),
        activities: [
            `Depart from ${formData.startLocation} to ${formData.destination}`,
            `Travel by ${formData.transport}`,
            'Check into accommodation',
            'Evening walk and local cuisine'
        ]
    });

    // Middle days
    for (let i = 2; i < duration; i++) {
        const currentDate = new Date(startDate);
        currentDate.setDate(startDate.getDate() + i - 1);

        itinerary.push({
            day: i,
            date: currentDate.toLocaleDateString(),
            activities: [
                'Breakfast at hotel',
                'Visit local attractions and landmarks',
                'Lunch at recommended restaurants',
                'Afternoon activities and shopping',
                'Dinner and cultural experiences'
            ]
        });
    }

    // Last day: Return (if round trip)
    if (formData.returnDate) {
        const returnDate = new Date(formData.returnDate);
        itinerary.push({
            day: duration,
            date: returnDate.toLocaleDateString(),
            activities: [
                'Morning breakfast and checkout',
                `Return journey to ${formData.startLocation} by ${formData.transport}`,
                'Arrive home safely'
            ]
        });
    }

    return itinerary;
}

function generateRecommendations(destination, transport) {
    const recommendations = {
        'Delhi': {
            attractions: ['Red Fort', 'India Gate', 'Qutub Minar', 'Lotus Temple'],
            food: ['Butter Chicken', 'Chole Bhature', 'Paratha', 'Lassi'],
            tips: ['Visit during winter for pleasant weather', 'Try street food from Karol Bagh']
        },
        'Mumbai': {
            attractions: ['Gateway of India', 'Marine Drive', 'Elephanta Caves', 'Chor Bazaar'],
            food: ['Vada Pav', 'Pav Bhaji', 'Fish Curry', 'Modak'],
            tips: ['Best time to visit October to May', 'Experience local trains for culture']
        },
        'Bangalore': {
            attractions: ['Lalbagh Botanical Garden', 'Bangalore Palace', 'Cubbon Park', 'Vidhana Soudha'],
            food: ['Biryani', 'Dosa', 'Bisi Bele Bath', 'Filter Coffee'],
            tips: ['Known as Silicon Valley of India', 'Great weather throughout the year']
        }
    };

    // Default recommendations if destination not found
    const defaultRecs = {
        attractions: ['Local Markets', 'Historical Sites', 'Parks and Gardens', 'Temples'],
        food: ['Local Cuisine', 'Street Food', 'Regional Specialties'],
        tips: ['Check weather before travel', 'Respect local customs', 'Try local transportation']
    };

    const cityRecs = recommendations[destination] || defaultRecs;

    return {
        ...cityRecs,
        transport: getTransportTips(transport, destination)
    };
}

function getTransportTips(transport, destination) {
    const tips = {
        'Flight': `Direct flights available to ${destination}. Check for deals on airline websites.`,
        'Train': `Comfortable train journeys to ${destination}. Consider AC coaches for long trips.`,
        'Bus': `Budget-friendly option to ${destination}. Choose Volvo buses for comfort.`,
        'Cab': `Convenient for short trips. Use apps like Ola/Uber for reliable service.`
    };
    return tips[transport] || 'Choose transportation based on your comfort and budget.';
}

function displayTripPlan(plan, formData) {
    // Remove existing plan display
    const existingPlan = document.querySelector('.trip-plan-display');
    if (existingPlan) {
        existingPlan.remove();
    }

    // Create plan display container
    const planContainer = document.createElement('div');
    planContainer.className = 'trip-plan-display';
    planContainer.innerHTML = `
        <div class="plan-header">
            <h3>Your Trip Plan: ${formData.startLocation} to ${formData.destination}</h3>
            <div class="plan-summary">
                <span class="duration">${plan.duration} Days</span>
                <span class="travelers">${formData.travelers} Traveler${formData.travelers > 1 ? 's' : ''}</span>
                <span class="transport">${formData.transport}</span>
            </div>
        </div>

        <div class="plan-costs">
            <h4>Trip Cost Breakdown</h4>
            <div class="cost-breakdown">
                <div class="cost-item">
                    <span>Transportation</span>
                    <span>₹${plan.costs.transport.toLocaleString()}</span>
                </div>
                <div class="cost-item">
                    <span>Accommodation</span>
                    <span>₹${plan.costs.accommodation.toLocaleString()}</span>
                </div>
                <div class="cost-item">
                    <span>Food</span>
                    <span>₹${plan.costs.food.toLocaleString()}</span>
                </div>
                <div class="cost-item">
                    <span>Activities</span>
                    <span>₹${plan.costs.activities.toLocaleString()}</span>
                </div>
                <div class="cost-item total">
                    <span>Total Estimated Cost</span>
                    <span>₹${plan.costs.total.toLocaleString()}</span>
                </div>
            </div>
        </div>

        <div class="plan-itinerary">
            <h4>Detailed Itinerary</h4>
            <div class="itinerary-days">
                ${plan.itinerary.map(day => `
                    <div class="itinerary-day">
                        <h5>Day ${day.day} - ${day.date}</h5>
                        <ul>
                            ${day.activities.map(activity => `<li>${activity}</li>`).join('')}
                        </ul>
                    </div>
                `).join('')}
            </div>
        </div>

        <div class="plan-recommendations">
            <h4>Recommendations for ${formData.destination}</h4>
            <div class="recommendations-grid">
                <div class="recommendation-section">
                    <h5>🏛️ Must Visit Places</h5>
                    <ul>
                        ${plan.recommendations.attractions.map(attr => `<li>${attr}</li>`).join('')}
                    </ul>
                </div>
                <div class="recommendation-section">
                    <h5>🍽️ Local Cuisine</h5>
                    <ul>
                        ${plan.recommendations.food.map(food => `<li>${food}</li>`).join('')}
                    </ul>
                </div>
                <div class="recommendation-section">
                    <h5>💡 Travel Tips</h5>
                    <ul>
                        ${plan.recommendations.tips.map(tip => `<li>${tip}</li>`).join('')}
                    </ul>
                </div>
                <div class="recommendation-section">
                    <h5>🚗 Transport Info</h5>
                    <p>${plan.recommendations.transport}</p>
                </div>
            </div>
        </div>

        <div class="plan-actions">
            <button onclick="printTripPlan()" class="print-btn">Print Plan</button>
            <button onclick="saveTripPlanToStorage()" class="save-btn">Save Plan</button>
        </div>
    `;

    // Insert after the form
    plannerForm.insertAdjacentElement('afterend', planContainer);

    // Scroll to plan
    planContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function printTripPlan() {
    window.print();
}

function saveTripPlanToStorage() {
    const planData = document.querySelector('.trip-plan-display');
    if (planData) {
        // Extract plan data from the DOM
        const planSummary = planData.querySelector('.plan-summary');
        const destination = planSummary ? planSummary.textContent.split(' to ')[1]?.split(' ')[0] : 'Unknown';

        // Get the current form data to reconstruct the plan
        const formData = {
            startLocation: document.getElementById('start-location')?.value || '',
            destination: document.getElementById('destination')?.value || destination,
            travelDate: document.getElementById('travel-date')?.value || '',
            returnDate: document.getElementById('return-date')?.value || '',
            travelers: parseInt(document.getElementById('travelers')?.value) || 1,
            transport: document.getElementById('transport')?.value || 'Flight'
        };

        // Generate the plan data
        const planDataObj = generateTripPlan(formData);
        saveTripPlan(planDataObj);
    } else {
        showToast('No trip plan to save', 'error');
    }
}

async function saveTripPlan(planData) {
    try {
        // Save to localStorage only
        const savedPlans = JSON.parse(localStorage.getItem('tripPlans') || '[]');
        savedPlans.push({
            ...planData,
            savedAt: new Date().toISOString(),
            id: Date.now()
        });
        localStorage.setItem('tripPlans', JSON.stringify(savedPlans));

        showToast('Trip plan saved locally!', 'success');

        // Update saved plans display
        displaySavedPlans();

    } catch (error) {
        console.error('Error saving trip plan:', error);
        showToast('Error saving trip plan', 'error');
    }
}

function displaySavedPlans() {
    const savedPlans = JSON.parse(localStorage.getItem('tripPlans') || '[]');
    const savedPlansContainer = document.getElementById('saved-plans-container');

    if (!savedPlansContainer) return;

    if (savedPlans.length === 0) {
        savedPlansContainer.innerHTML = '<p class="no-plans">No saved plans yet. Create your first trip plan!</p>';
        return;
    }

    savedPlansContainer.innerHTML = savedPlans.map(plan => `
        <div class="saved-plan-card" data-plan-id="${plan.id}">
            <div class="plan-card-header">
                <h4>${plan.startLocation} → ${plan.destination}</h4>
                <span class="plan-date">${new Date(plan.travelDate).toLocaleDateString()}</span>
            </div>
            <div class="plan-card-details">
                <p><strong>Travelers:</strong> ${plan.travelers}</p>
                <p><strong>Transport:</strong> ${plan.transport}</p>
                <p><strong>Total Cost:</strong> ₹${plan.totalCost.toLocaleString()}</p>
                <p><strong>Saved:</strong> ${new Date(plan.savedAt).toLocaleDateString()}</p>
            </div>
            <div class="plan-card-actions">
                <button onclick="loadSavedPlan('${plan.id}')" class="load-btn">Load Plan</button>
                <button onclick="deleteSavedPlan('${plan.id}')" class="delete-btn">Delete</button>
            </div>
        </div>
    `).join('');
}

function loadSavedPlan(planId) {
    const savedPlans = JSON.parse(localStorage.getItem('tripPlans') || '[]');
    const plan = savedPlans.find(p => p.id.toString() === planId);

    if (plan) {
        // Populate form with plan data
        document.getElementById('start-location').value = plan.startLocation;
        document.getElementById('destination').value = plan.destination;
        document.getElementById('travel-date').value = plan.travelDate;
        document.getElementById('return-date').value = plan.returnDate || '';
        document.getElementById('travelers').value = plan.travelers;
        document.getElementById('transport').value = plan.transport;

        // Display the plan
        displayTripPlan(plan);

        showToast('Plan loaded successfully!', 'success');
    }
}

function deleteSavedPlan(planId) {
    if (confirm('Are you sure you want to delete this trip plan?')) {
        const savedPlans = JSON.parse(localStorage.getItem('tripPlans') || '[]');
        const updatedPlans = savedPlans.filter(p => p.id.toString() !== planId);
        localStorage.setItem('tripPlans', JSON.stringify(updatedPlans));

        displaySavedPlans();
        showToast('Plan deleted successfully!', 'success');
    }
}